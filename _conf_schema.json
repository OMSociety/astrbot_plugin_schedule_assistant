{
 "enable_schedule_reminder": {
  "type": "bool",
  "default": false,
  "description": "日程 LLM 智能提醒开关"
 },
 "schedule_reminder_minutes": {
  "type": "int",
  "default": 10,
  "description": "日程提前提醒分钟数"
 },
 "enable_morning_report": {
  "type": "bool",
  "default": true,
  "description": "早安播报开关"
 },
 "morning_report_time": {
  "type": "string",
  "default": "09:00",
  "description": "早安播报时间"
 },
 "enable_bath_reminder": {
  "type": "bool",
  "default": true,
  "description": "洗澡提醒开关"
 },
 "bath_time": {
  "type": "string",
  "default": "22:00",
  "description": "洗澡提醒时间"
 },
 "enable_sleep_reminder": {
  "type": "bool",
  "default": true,
  "description": "睡觉提醒开关"
 },
 "sleep_time": {
  "type": "string",
  "default": "23:00",
  "description": "睡觉提醒时间"
 },
 "enable_water_reminder": {
  "type": "bool",
  "default": true,
  "description": "喝水提醒开关"
 },
 "water_interval": {
  "type": "int",
  "default": 90,
  "description": "喝水提醒间隔（分钟）"
 },
 "water_start_time": {
  "type": "string",
  "default": "09:30",
  "description": "喝水开始时间"
 },
 "water_end_time": {
  "type": "string",
  "default": "21:30",
  "description": "喝水结束时间"
 },
 "enable_apple_calendar_sync": {
  "type": "bool",
  "default": false,
  "description": "Apple 日历双向同步开关"
 },
 "apple_calendar_sync_interval": {
  "type": "int",
  "default": 30,
  "description": "Apple 日历同步间隔（分钟）"
 },
 "apple_calendar": {
  "type": "object",
  "description": "Apple 日历认证与同步配置",
  "children": {
   "enable_sync": {
    "type": "bool",
    "default": false,
    "description": "启用日历写入（本地新建日程 → Apple 日历）"
   },
   "username": {
    "type": "string",
    "default": "",
    "description": "Apple ID 邮箱（如 xxx@icloud.com）"
   },
   "app_password": {
    "type": "string",
    "default": "",
    "description": "Apple 专用密码（去 appleid.apple.com → 登录 → 安全性 → 生成 App 专用密码）"
   },
   "calendar_id": {
    "type": "string",
    "default": "",
    "description": "日历 UUID 或名称（如「日程」），用于写入。不填默认第一个日历"
   }
  }
 },
 "webcal_urls": {
  "type": "list",
  "items": {"type": "string"},
  "default": [],
  "description": "WebCal 共享日历链接列表",
  "placeholder": "webcal://pXXX-caldav.icloud.com.cn/published/..."
 },
 "notion_db_ids": {
  "type": "list",
  "items": {"type": "object", "properties": {"name": {"type": "string"}, "id": {"type": "string"}}},
  "default": [],
  "description": "Notion 数据库 ID 列表（格式：[{"name": "事务", "id": "xxx..."}, ...]），在 Notion 页面链接里找（如 notion.so/workspace/xxxxxxxx-xxxxxxxxxx?v=... 中的 ID）"
 },
 "maton_api_key": {
  "type": "string",
  "default": "",
  "description": "Maton API Key（建议填写，与 api-gateway Skill 保持一致）。从 https://www.maton.ai 注册获取"
 },
 "weather_api_key": {
  "type": "string",
  "default": "",
  "description": "心知天气 API Key，用于早报天气。从 seniverse.com 获取（免费版够用）"
 },
 "weather_city": {
  "type": "string",
  "default": "杭州",
  "description": "默认查询天气的城市"
 },
 "whitelist_qq_ids": {
  "type": "list",
  "items": {"type": "string"},
  "default": [],
  "description": "白名单 QQ 号（只有这些 QQ 能收到自动提醒）"
 }
}